# TennisIQ — environment variable template.
# Copy to `.env` and fill in real values. Never commit `.env`.

# API host/port (App Runner overrides to 0.0.0.0:8080 via start.sh)
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated origins for CORS. main.py currently hardcodes the production
# list; this variable is read by src/api/config.py and is the fallback path.
CORS_ORIGINS=https://tennisiq-one.vercel.app,https://d3aogk1vtnp91d.cloudfront.net,http://localhost:3000,http://localhost:8080

# No database is required. Session 16.1 refactored every previously
# DB-backed endpoint to read from in-memory engine state (Glicko ratings,
# player attributes, H2H cache) and JSON files (atp_calendar_2026.json).

# AWS credentials for tools that read tennisiq-data-assets directly. On
# App Runner the instance role provides these implicitly; locally they're
# read from this file by the dotenv loader.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Anthropic API key for the Haiku 4.5 editorial layer (Phase 11). Without
# this set, the editor falls back to the raw candidate headline.
ANTHROPIC_API_KEY=

# Bearer token for the /admin/insights/override endpoint (Phase 12).
ADMIN_TOKEN=
